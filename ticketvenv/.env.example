# Шаблон переменных окружения для проекта HelpDesk IT.
# Скопируйте в .env и подставьте реальные значения. .env в git НЕ коммитим.

# --- Django ---
DJANGO_SECRET_KEY=замените-на-свой-длинный-случайный-ключ
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.ru

# --- Почта (Этап 4). Пример для Яндекса ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-mailbox@yandex.ru
EMAIL_HOST_PASSWORD=app-password-here
DEFAULT_FROM_EMAIL=your-mailbox@yandex.ru

# --- LDAP / Active Directory (Этап 4). Параметры тестовые ---
LDAP_ENABLED=False
LDAP_SERVER_URI=ldap://192.168.0.10:389
LDAP_BIND_DN=cn=admin,dc=example,dc=local
LDAP_BIND_PASSWORD=test-password
